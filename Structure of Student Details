#include <stdio.h>

struct Student {
    int rollNo;
    char name[50];
    float gpa;
};

int main() {
    int n;
    printf("Enter number of students: ");
    scanf("%d", &n);

    struct Student s[n];

    for (int i = 0; i < n; i++) {
        printf("\nEnter details for Student %d:\n", i + 1);
        printf("Roll Number: ");
        scanf("%d", &s[i].rollNo);
        printf("Name: ");
        scanf("%s", s[i].name);
        printf("GPA: ");
        scanf("%f", &s[i].gpa);
    }

    printf("\n--- Student Details ---\n");
    for (int i = 0; i < n; i++) {
        printf("Roll No: %d, Name: %s, GPA: %.2f\n", s[i].rollNo, s[i].name, s[i].gpa);
    }

    return 0;
}
