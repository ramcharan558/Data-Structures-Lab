#include <stdio.h>

void display(int arr[], int n) {
    printf("Array elements: ");
    for (int i = 0; i < n; i++) printf("%d ", arr[i]);
    printf("\n");
}

int main() {
    int arr[100], n = 0, choice, element, pos;

    printf("Enter number of initial elements: ");
    scanf("%d", &n);
    printf("Enter %d elements:\n", n);
    for (int i = 0; i < n; i++) scanf("%d", &arr[i]);

    while (1) {
        printf("\n--- Array Manipulation Menu ---\n");
        printf("1. Insertion\n2. Deletion\n3. Modification\n4. Replacement\n5. Display\n6. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter element and position (0 to %d): ", n);
                scanf("%d %d", &element, &pos);
                if (pos < 0 || pos > n) {
                    printf("Invalid position!\n");
                } else {
                    for (int i = n; i > pos; i--) arr[i] = arr[i - 1];
                    arr[pos] = element;
                    n++;
                }
                break;

            case 2:
                printf("Enter position to delete (0 to %d): ", n - 1);
                scanf("%d", &pos);
                if (pos < 0 || pos >= n) {
                    printf("Invalid position!\n");
                } else {
                    for (int i = pos; i < n - 1; i++) arr[i] = arr[i + 1];
                    n--;
                }
                break;

            case 3:
                int oldVal, newVal, found = 0;
                printf("Enter value to modify and new value: ");
                scanf("%d %d", &oldVal, &newVal);
                for (int i = 0; i < n; i++) {
                    if (arr[i] == oldVal) {
                        arr[i] = newVal;
                        found = 1;
                    }
                }
                if (!found) printf("Value not found!\n");
                break;

            case 4:
                printf("Enter position (0 to %d) and new element: ", n - 1);
                scanf("%d %d", &pos, &element);
                if (pos < 0 || pos >= n) {
                    printf("Invalid position!\n");
                } else {
                    arr[pos] = element;
                }
                break;

            case 5:
                display(arr, n);
                break;

            case 6:
                return 0;

            default:
                printf("Invalid choice!\n");
        }
    }
}
